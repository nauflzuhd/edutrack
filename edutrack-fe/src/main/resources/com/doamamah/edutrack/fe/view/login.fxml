<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>

<!--
    login.fxml — EduTrack Login, Register & Forgot Password Page
    Design: Split-screen, warm cream branding + centered white form cards + playful background decals (Orange theme)
-->
<HBox
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.doamamah.edutrack.fe.controller.LoginController"
    styleClass="login-root"
    prefWidth="1024"
    prefHeight="768">

    <!-- ============================================================
         PANEL KIRI — Branding, krem hangat + decal background
         ============================================================ -->
    <StackPane HBox.hgrow="ALWAYS" maxWidth="750" prefWidth="512" minWidth="420" styleClass="login-left-pane">
        <!-- Decal Hiasan Background (Absolut, dengan Responsive Anchors) -->
        <AnchorPane mouseTransparent="true" StackPane.alignment="CENTER">
            <SVGPath content="M10 0 L13 7 L20 8 L15 13 L16 20 L10 16 L4 20 L5 13 L0 8 L7 7 Z" styleClass="bg-decor-star" scaleX="1.2" scaleY="1.2" AnchorPane.topAnchor="120.0" AnchorPane.leftAnchor="80.0"/>
            <SVGPath content="M10 0 L13 7 L20 8 L15 13 L16 20 L10 16 L4 20 L5 13 L0 8 L7 7 Z" styleClass="bg-decor-star-small" scaleX="0.8" scaleY="0.8" AnchorPane.topAnchor="220.0" AnchorPane.rightAnchor="80.0"/>
            <SVGPath content="M10 0 L13 7 L20 8 L15 13 L16 20 L10 16 L4 20 L5 13 L0 8 L7 7 Z" styleClass="bg-decor-star-small" scaleX="0.7" scaleY="0.7" AnchorPane.bottomAnchor="120.0" AnchorPane.leftAnchor="60.0"/>
            
            <!-- Crescent Moon -->
            <SVGPath content="M12 2a15.3 15.3 0 0 1 4 7 15.3 15.3 0 0 1-4 7 10 10 0 0 0 0-14z" styleClass="bg-decor-moon" scaleX="1.6" scaleY="1.6" AnchorPane.topAnchor="100.0" AnchorPane.rightAnchor="180.0"/>
            <!-- Wave Curves (Starry Night theme) -->
            <SVGPath content="M 0,20 C 150,120 350,-80 500,20" styleClass="bg-decor-wave" scaleX="1.2" scaleY="1.0" AnchorPane.topAnchor="380.0" AnchorPane.leftAnchor="40.0"/>
            <SVGPath content="M 0,40 C 120,-40 280,120 400,40" styleClass="bg-decor-wave" scaleX="1.1" scaleY="0.9" AnchorPane.bottomAnchor="180.0" AnchorPane.leftAnchor="140.0"/>
            
            <!-- Graduation Cap -->
            <SVGPath content="M12 3 L2 8 L12 13 L22 8 Z M5 12 V16 C5 17.5 8 19 12 19 C16 19 19 17.5 19 16 V12" styleClass="bg-decor-cap" scaleX="1.5" scaleY="1.5" AnchorPane.bottomAnchor="240.0" AnchorPane.rightAnchor="120.0"/>
            <!-- Open Book -->
            <SVGPath content="M12 21 C9 21 4 19 2 19 V4 C4 4 9 6 12 6 C15 6 20 4 22 4 V19 C20 19 15 21 12 21 Z M12 6 V21" styleClass="bg-decor-book" scaleX="1.3" scaleY="1.3" AnchorPane.topAnchor="320.0" AnchorPane.leftAnchor="120.0"/>
            <!-- Lightbulb -->
            <SVGPath content="M9 21h6v-2H9v2zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7z" styleClass="bg-decor-lightbulb" scaleX="1.4" scaleY="1.4" AnchorPane.topAnchor="150.0" AnchorPane.leftAnchor="220.0"/>
            <!-- Owl Outline -->
            <SVGPath content="M12 2c-3.31 0-6 2.69-6 6v4c0 3.31 2.69 6 6 6s6-2.69 6-6V8c0-3.31-2.69-6-6-6zm-2 5c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm4 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-2 7c-1.1 0-2-.9-2-2h4c0 1.1-.9 2-2 2z" styleClass="bg-decor-owl" scaleX="1.5" scaleY="1.5" AnchorPane.bottomAnchor="100.0" AnchorPane.leftAnchor="320.0"/>
        </AnchorPane>

        <!-- Konten Utama Kiri -->
        <VBox
            styleClass="login-left-panel"
            alignment="CENTER"
            spacing="20">
            <padding><Insets top="40" right="56" bottom="40" left="56"/></padding>

            <!-- Logo kustom: Maskot Wajah + Brand (Orange theme) -->
            <HBox spacing="16" alignment="CENTER">
                <ImageView fitWidth="68" fitHeight="68" preserveRatio="true" smooth="true">
                    <image>
                        <Image url="@../images/mascot_face.png"/>
                    </image>
                </ImageView>
                <VBox spacing="0" alignment="CENTER_LEFT">
                    <Label text="EduTrack" styleClass="hero-title" style="-fx-font-size: 28px;"/>
                    <Label text="by Doa Mamah 2.0" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- Hero Text -->
            <VBox spacing="4" alignment="CENTER">
                <Label text="Belajar Lebih Seru," styleClass="hero-title" style="-fx-font-size: 30px; -fx-text-alignment: center;"/>
                <Label text="Raih Prestasimu!" styleClass="hero-title" style="-fx-text-fill: #FF7A00; -fx-font-size: 30px; -fx-text-alignment: center;"/>
            </VBox>

            <Label text="Platform e-learning interaktif untuk pengajar dan siswa. Akses materi video, teks, dan kuis kapan saja." styleClass="hero-subtitle" wrapText="true" style="-fx-text-alignment: center;"/>

            <!-- Beautiful study illustration from resources -->
            <StackPane alignment="CENTER" maxWidth="Infinity">
                <ImageView fitWidth="260" preserveRatio="true" smooth="true">
                    <image>
                        <Image url="@../images/learning_illustration.png"/>
                    </image>
                </ImageView>
            </StackPane>

            <!-- Statistik singkat — hiasan decorative -->
            <HBox spacing="16" alignment="CENTER">
                <VBox spacing="2" alignment="CENTER" styleClass="left-stat-box" prefWidth="100">
                    <Label text="100+" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #FF7A00;"/>
                    <Label text="Materi" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;"/>
                </VBox>
                <VBox spacing="2" alignment="CENTER" styleClass="left-stat-box" prefWidth="100">
                    <Label text="500+" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #059669;"/>
                    <Label text="Siswa" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;"/>
                </VBox>
                <VBox spacing="2" alignment="CENTER" styleClass="left-stat-box" prefWidth="100">
                    <Label text="50+" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #D97706;"/>
                    <Label text="Kuis" style="-fx-font-size: 11px; -fx-text-fill: #6B7280;"/>
                </VBox>
            </HBox>

            <!-- Daftar Fitur -->
            <VBox spacing="10" alignment="CENTER">
                <HBox spacing="10" alignment="CENTER">
                    <StackPane>
                        <Circle radius="12" fill="#FFF0E0"/>
                        <Label text="✓" styleClass="feature-icon"/>
                    </StackPane>
                    <Label text="Video dan materi teks berkualitas" styleClass="feature-text"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER">
                    <StackPane>
                        <Circle radius="12" fill="#ECFDF5"/>
                        <Label text="✓" style="-fx-font-size: 14px; -fx-text-fill: #059669; -fx-font-weight: bold;"/>
                    </StackPane>
                    <Label text="Kuis interaktif untuk evaluasi belajar" styleClass="feature-text"/>
                </HBox>
            </VBox>
        </VBox>
    </StackPane>

    <!-- ============================================================
         PANEL KANAN — Form Cards Centered + decal background
         ============================================================ -->
    <StackPane HBox.hgrow="ALWAYS" prefWidth="512">
        <!-- Decal Hiasan Background (Absolut, dengan Responsive Anchors) -->
        <AnchorPane mouseTransparent="true" StackPane.alignment="CENTER">
            <SVGPath content="M10 0 L13 7 L20 8 L15 13 L16 20 L10 16 L4 20 L5 13 L0 8 L7 7 Z" styleClass="bg-decor-star" scaleX="1.1" scaleY="1.1" AnchorPane.topAnchor="180.0" AnchorPane.leftAnchor="140.0"/>
            <SVGPath content="M10 0 L13 7 L20 8 L15 13 L16 20 L10 16 L4 20 L5 13 L0 8 L7 7 Z" styleClass="bg-decor-star-small" scaleX="0.8" scaleY="0.8" AnchorPane.bottomAnchor="120.0" AnchorPane.rightAnchor="140.0"/>
            
            <!-- Crescent Moon -->
            <SVGPath content="M12 2a15.3 15.3 0 0 1 4 7 15.3 15.3 0 0 1-4 7 10 10 0 0 0 0-14z" styleClass="bg-decor-moon" scaleX="1.4" scaleY="1.4" AnchorPane.bottomAnchor="160.0" AnchorPane.leftAnchor="60.0"/>
            <!-- Wave Curves (Starry Night theme) -->
            <SVGPath content="M 0,20 C 150,120 350,-80 500,20" styleClass="bg-decor-wave" scaleX="1.0" scaleY="0.9" AnchorPane.topAnchor="100.0" AnchorPane.rightAnchor="50.0"/>
            <SVGPath content="M 0,40 C 120,-40 280,120 400,40" styleClass="bg-decor-wave" scaleX="1.0" scaleY="0.8" AnchorPane.bottomAnchor="260.0" AnchorPane.rightAnchor="80.0"/>
            
            <!-- Lightbulb -->
            <SVGPath content="M9 21h6v-2H9v2zm3-19C8.14 2 5 5.14 5 9c0 2.38 1.19 4.47 3 5.74V17c0 .55.45 1 1 1h6c.55 0 1-.45 1-1v-2.26c1.81-1.27 3-3.36 3-5.74 0-3.86-3.14-7-7-7z" styleClass="bg-decor-lightbulb" scaleX="1.3" scaleY="1.3" AnchorPane.bottomAnchor="200.0" AnchorPane.leftAnchor="100.0"/>
            <!-- Graduation Cap -->
            <SVGPath content="M12 3 L2 8 L12 13 L22 8 Z M5 12 V16 C5 17.5 8 19 12 19 C16 19 19 17.5 19 16 V12" styleClass="bg-decor-cap" scaleX="1.4" scaleY="1.4" AnchorPane.topAnchor="220.0" AnchorPane.rightAnchor="100.0"/>
        </AnchorPane>

        <VBox
            styleClass="login-right-pane"
            alignment="CENTER">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>

            <StackPane>
                <!-- ==================== CARD 1: LOGIN ==================== -->
                <VBox
                    fx:id="loginCard"
                    styleClass="login-form-card"
                    spacing="18"
                    alignment="CENTER"
                    visible="true"
                    managed="true">

                    <!-- Judul Form -->
                    <VBox spacing="6" alignment="CENTER">
                        <Label text="Selamat Datang!" styleClass="login-form-title"/>
                        <Label text="Masuk untuk mulai belajar hari ini." styleClass="login-form-subtitle"/>
                    </VBox>

                    <!-- Kotak info akun demo -->
                    <VBox styleClass="demo-hint-box" spacing="6">
                        <Label text="Akun Demo (tanpa backend)" styleClass="demo-hint-title"/>
                        <Label text="Siswa    →  siswa / 123" styleClass="demo-hint-text"/>
                        <Label text="Pengajar →  guru  / 123" styleClass="demo-hint-text"/>
                    </VBox>

                    <!-- Username -->
                    <VBox spacing="6" alignment="CENTER_LEFT" maxWidth="Infinity">
                        <Label text="Username" styleClass="input-label"/>
                        <TextField
                            fx:id="usernameField"
                            styleClass="input-field"
                            promptText="Masukkan username Anda"
                            maxWidth="Infinity"/>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="6" alignment="CENTER_LEFT" maxWidth="Infinity">
                        <HBox alignment="BOTTOM_LEFT">
                            <Label text="Password" styleClass="input-label"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Hyperlink text="Lupa Password?" onAction="#showForgotPassword" style="-fx-text-fill: #FF7A00; -fx-font-size: 12px; -fx-padding: 0;"/>
                        </HBox>
                        <PasswordField
                            fx:id="passwordField"
                            styleClass="input-field"
                            promptText="Masukkan password Anda"
                            maxWidth="Infinity"/>
                    </VBox>

                    <!-- Error -->
                    <Label
                        fx:id="errorLabel"
                        styleClass="error-label"
                        text=""
                        wrapText="true"
                        maxWidth="Infinity"
                        visible="false"
                        managed="false"/>

                    <Region prefHeight="4"/>

                    <!-- Tombol Login -->
                    <Button
                        fx:id="loginButton"
                        text="Masuk"
                        styleClass="btn-login"
                        maxWidth="Infinity"
                        onAction="#handleLogin"/>

                    <!-- Loading -->
                    <ProgressIndicator
                        fx:id="loadingIndicator"
                        visible="false"
                        managed="false"
                        prefHeight="32"
                        prefWidth="32"/>

                    <!-- Divider -->
                    <Separator/>

                    <!-- Belum punya akun? -->
                    <HBox alignment="CENTER" spacing="4">
                        <Label text="Belum punya akun?" style="-fx-text-fill: #6B7280; -fx-font-size: 13px;"/>
                        <Hyperlink text="Daftar sekarang" onAction="#showRegister" style="-fx-text-fill: #FF7A00; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 0;"/>
                    </HBox>
                </VBox>

                <!-- ==================== CARD 2: REGISTER ==================== -->
                <VBox
                    fx:id="registerCard"
                    styleClass="login-form-card"
                    spacing="14"
                    alignment="CENTER"
                    visible="false"
                    managed="false">

                    <!-- Judul Form -->
                    <VBox spacing="6" alignment="CENTER">
                        <Label text="Daftar Akun Baru" styleClass="login-form-title"/>
                        <Label text="Bergabunglah dengan platform EduTrack." styleClass="login-form-subtitle"/>
                    </VBox>

                    <!-- Username -->
                    <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="Infinity">
                        <Label text="Username" styleClass="input-label"/>
                        <TextField
                            fx:id="regUsernameField"
                            styleClass="input-field"
                            promptText="Contoh: budisantoso"
                            maxWidth="Infinity"/>
                    </VBox>

                    <!-- Nama Lengkap -->
                    <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="Infinity">
                        <Label text="Nama Lengkap" styleClass="input-label"/>
                        <TextField
                            fx:id="regFullNameField"
                            styleClass="input-field"
                            promptText="Masukkan nama lengkap Anda"
                            maxWidth="Infinity"/>
                    </VBox>

                    <!-- Email -->
                    <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="Infinity">
                        <Label text="Email" styleClass="input-label"/>
                        <TextField
                            fx:id="regEmailField"
                            styleClass="input-field"
                            promptText="Contoh: budi@email.com"
                            maxWidth="Infinity"/>
                    </VBox>

                    <!-- Peran / Role -->
                    <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="Infinity">
                        <Label text="Saya adalah seorang" styleClass="input-label"/>
                        <ComboBox
                            fx:id="regRoleCombo"
                            styleClass="combo-box, input-field"
                            maxWidth="Infinity"/>
                    </VBox>

                    <!-- Password -->
                    <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="Infinity">
                        <Label text="Password" styleClass="input-label"/>
                        <PasswordField
                            fx:id="regPasswordField"
                            styleClass="input-field"
                            promptText="Buat password minimal 6 karakter"
                            maxWidth="Infinity"/>
                    </VBox>

                    <!-- Konfirmasi Password -->
                    <VBox spacing="4" alignment="CENTER_LEFT" maxWidth="Infinity">
                        <Label text="Konfirmasi Password" styleClass="input-label"/>
                        <PasswordField
                            fx:id="regConfirmPasswordField"
                            styleClass="input-field"
                            promptText="Ulangi password Anda"
                            maxWidth="Infinity"/>
                    </VBox>

                    <!-- Button Daftar -->
                    <Button
                        text="Daftar Sekarang"
                        styleClass="btn-login"
                        maxWidth="Infinity"
                        onAction="#handleRegister"/>

                    <!-- Divider -->
                    <Separator/>

                    <!-- Sudah punya akun? -->
                    <HBox alignment="CENTER" spacing="4">
                        <Label text="Sudah punya akun?" style="-fx-text-fill: #6B7280; -fx-font-size: 13px;"/>
                        <Hyperlink text="Masuk di sini" onAction="#showLogin" style="-fx-text-fill: #FF7A00; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 0;"/>
                    </HBox>
                </VBox>

                <!-- ==================== CARD 3: FORGOT PASSWORD ==================== -->
                <VBox
                    fx:id="forgotPasswordCard"
                    styleClass="login-form-card"
                    spacing="18"
                    alignment="CENTER"
                    visible="false"
                    managed="false">

                    <!-- Judul Form -->
                    <VBox spacing="6" alignment="CENTER">
                        <Label text="Lupa Password?" styleClass="login-form-title"/>
                        <Label text="Masukkan email untuk menerima tautan pemulihan." styleClass="login-form-subtitle" wrapText="true" style="-fx-text-alignment: center;"/>
                    </VBox>

                    <!-- Email Input -->
                    <VBox spacing="6" alignment="CENTER_LEFT" maxWidth="Infinity">
                        <Label text="Email Terdaftar" styleClass="input-label"/>
                        <TextField
                            fx:id="forgotEmailField"
                            styleClass="input-field"
                            promptText="Contoh: nama@email.com"
                            maxWidth="Infinity"/>
                    </VBox>

                    <!-- Button Send -->
                    <Button
                        text="Kirim Tautan Pemulihan"
                        styleClass="btn-login"
                        maxWidth="Infinity"
                        onAction="#handleForgotPassword"/>

                    <!-- Divider -->
                    <Separator/>

                    <!-- Kembali ke Login -->
                    <Hyperlink text="Kembali ke halaman Masuk" onAction="#showLogin" style="-fx-text-fill: #FF7A00; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 0;"/>
                </VBox>
            </StackPane>
        </VBox>
    </StackPane>
</HBox>
